	branch = main
[submodule "third_party/generative_agents"]
	path = third_party/generative_agents
	url = https://github.com/joonspk-research/generative_agents.git
	branch = main
[submodule "models/lingbot-map"]
	path = models/lingbot-map
	url = https://github.com/Robbyant/lingbot-map.git
	branch = main
